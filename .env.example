# ─── Supabase (필수) ───
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Anthropic AI (필수) ───
ANTHROPIC_API_KEY=

# ─── Stripe 결제 (선택 — 결제 기능 사용 시) ───
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_TICKET_PRICE_ID=
STRIPE_BUNDLE_PRICE_ID=

# ─── Toss Payments (선택 — 한국 결제 시) ───
NEXT_PUBLIC_TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
TOSS_WEBHOOK_SECRET=
# 결제위젯 키 (카카오페이/네이버페이/토스페이 지원 — 사업자등록 후 발급)
NEXT_PUBLIC_TOSS_WIDGET_KEY=
TOSS_WIDGET_SECRET_KEY=

# ─── 접근 제한 (선택 — 설정 시 비밀번호 필요) ───
# SITE_ACCESS_KEY=

# ─── Analytics (선택) ───
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# ─── 관리자 (선택 — 관찰성 API 접근 제한) ───
# 쉼표 구분 UUID 목록 (예: "uuid1,uuid2")
# ADMIN_USER_IDS=

# ─── Kakao 공유 (선택 — 카카오톡 공유 기능 사용 시) ───
# NEXT_PUBLIC_KAKAO_JS_KEY=

# ─── App ───
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
